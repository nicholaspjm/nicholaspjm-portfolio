# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-alt/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Held imports from the old Cargo site (nicholaspjm.com), documented in
# docs/cargo-import.md. All three held projects are now promoted to pages
# (pitch-far-from-god, atmos-norla-dome, thread-congee-club); their committed
# media is the web-ready images + .mp4 clips.

# public/images/projects and /tools are GENERATED: scripts/scan-images.mjs
# fills them from the content/ tree before every dev/build. The tree is the
# committed source.
/public/images/projects/
/public/images/thumbs/
/public/images/tools/

# Source videos don't play in-browser. They are transcoded to web .mp4 by
# scripts/convert-videos.mjs; only those .mp4 outputs (in public/videos) are
# committed. The heavy originals in the content tree stay local.
/content/**/*.[mM][oO][vV]
/content/**/*.[mM][pP]4
/content/**/*.[wW][eE][bB][mM]
/content/**/*.[mM]4[vV]
/public/videos/projects/**/*.[mM][oO][vV]
# For The Cause is promoted, but only the clips used on the page are committed;
# the rest stay downloaded locally (add them here to a block/gallery to publish).
/public/videos/projects/for-the-cause/03.mov
/public/videos/projects/for-the-cause/04.mov
/public/videos/projects/for-the-cause/06.mov
/public/videos/projects/for-the-cause/07.mov
/public/videos/projects/for-the-cause/08.mov
/public/videos/projects/for-the-cause/09.mov

# Generated each build by scan-images (last-updated date); not committed.
/src/content/build-info.ts

# Cloudflare Pages direct-upload package (regenerate: npm run build, then re-zip)
/cloudflare-upload/
/nicholaspjm-cloudflare.zip
