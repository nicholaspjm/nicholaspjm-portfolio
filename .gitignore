# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Held imports from the old Cargo site (nicholaspjm.com), documented in
# docs/cargo-import.md. All three held projects are now promoted to pages
# (pitch-far-from-god, atmos-norla-dome, thread-congee-club); their committed
# media is the web-ready images + .mp4 clips.

# Source videos dropped into image folders don't play in-browser. They are
# transcoded to public/videos/ by scripts/convert-videos.mjs; only the web .mp4
# outputs are committed. Keep the heavy originals local.
/public/images/projects/**/*.[mM][oO][vV]
/public/images/projects/**/*.[mM][pP]4
/public/images/projects/**/*.[wW][eE][bB][mM]
# For The Cause is promoted, but only the clips used on the page are committed;
# the rest stay downloaded locally (add them here to a block/gallery to publish).
/public/videos/projects/for-the-cause/03.mov
/public/videos/projects/for-the-cause/04.mov
/public/videos/projects/for-the-cause/06.mov
/public/videos/projects/for-the-cause/07.mov
/public/videos/projects/for-the-cause/08.mov
/public/videos/projects/for-the-cause/09.mov
